{
  "name": "@storm/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./dto": {
      "types": "./dist/dto/index.d.ts",
      "import": "./dist/dto/index.js"
    },
    "./proto": {
      "types": "./dist/proto/index.d.ts",
      "import": "./dist/proto/index.js"
    }
  },
  "files": ["dist", "proto"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@storm/tsconfig": "workspace:*",
    "@storm/eslint-config": "workspace:*",
    "@types/node": "20.16.5",
    "typescript": "5.5.4",
    "vitest": "2.1.1",
    "eslint": "8.57.1"
  }
}
