{
  "name": "storm",
  "version": "0.0.0",
  "private": true,
  "description": "Storm — Flipkart-style e-commerce platform (Stage 1, single-seller).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "seed:all": "tsx scripts/seed/index.ts"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "eslint": "8.57.1",
    "prettier": "3.3.3",
    "tsx": "4.19.1",
    "turbo": "2.1.3",
    "typescript": "5.5.4"
  }
}
