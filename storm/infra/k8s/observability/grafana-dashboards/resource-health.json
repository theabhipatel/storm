{
  "title": "Storm — Resource Health (USE)",
  "uid": "storm-resource-health",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["storm", "infra"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod CPU utilisation",
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"storm.*\"}[5m]))" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pod memory (resident, MB)",
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"storm.*\"}) / 1024 / 1024" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DB connection pool in-use",
      "targets": [
        { "expr": "pg_stat_activity_count{datname=~\"storm_.+\"}", "legendFormat": "{{datname}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Kafka consumer lag",
      "targets": [
        { "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}}/{{topic}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Redis memory used (MB)",
      "targets": [
        { "expr": "redis_memory_used_bytes / 1024 / 1024" }
      ]
    }
  ]
}
