// media-service Prisma schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaStatus {
  pending
  confirmed
  ready
  failed
}

enum ThumbnailVariant {
  sm
  md
  lg
}

model MediaAsset {
  id            String      @id @db.Uuid
  s3Key         String      @unique @map("s3_key")
  contentType   String      @map("content_type")
  sizeBytes     Int         @map("size_bytes")
  width         Int?
  height        Int?
  status        MediaStatus @default(pending)
  uploadedBy    String      @map("uploaded_by") @db.Uuid
  altText       String?     @map("alt_text")
  failureReason String?     @map("failure_reason")
  retryCount    Int         @default(0) @map("retry_count")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  confirmedAt   DateTime?   @map("confirmed_at")
  readyAt       DateTime?   @map("ready_at")

  thumbnails Thumbnail[]

  @@index([status, updatedAt])
  @@map("media_assets")
}

model Thumbnail {
  id           String           @id @db.Uuid
  mediaAssetId String           @map("media_asset_id") @db.Uuid
  variant      ThumbnailVariant
  s3Key        String           @map("s3_key")
  width        Int
  height       Int
  createdAt    DateTime         @default(now()) @map("created_at")

  asset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, variant])
  @@map("thumbnails")
}

model Outbox {
  id          String    @id @db.Uuid
  aggregateId String    @map("aggregate_id") @db.Uuid
  eventType   String    @map("event_type")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([publishedAt, createdAt])
  @@map("outbox")
}
