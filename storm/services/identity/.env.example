# Identity service environment template. Copy to .env and fill in.
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

DATABASE_URL=postgresql://identity:identity_pw@localhost:5432/identity?schema=public
REDIS_URL=redis://localhost:6379

KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=identity-service

# RS256 keypair (base64-encoded PEM). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem  ->  JWT_PRIVATE_KEY
#   base64 -w0 pub.pem   ->  JWT_PUBLIC_KEY
JWT_KID=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=storm-identity
JWT_AUDIENCE=storm

ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800
EMAIL_VERIFY_TTL_SEC=86400
PASSWORD_RESET_TTL_SEC=1800
OTP_TTL_SEC=300
OAUTH_STATE_TTL_SEC=300

COOKIE_DOMAIN=
COOKIE_SECURE=false

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3200/auth/login/google/callback

HIBP_USER_AGENT=storm-identity

WEB_APP_ORIGIN=http://localhost:3200
ADMIN_APP_ORIGIN=http://localhost:3300

# Twilio (test creds work). Read by notification-service, not identity-service.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
