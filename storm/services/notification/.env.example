# Notification service environment template. Copy to .env and fill in.
NODE_ENV=development
PORT=3010
LOG_LEVEL=debug

MONGO_URL=mongodb://notification:notification_pw@localhost:27018/notification?authSource=notification
MONGO_DB_NAME=notification

KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=notification-service
KAFKA_CONSUMER_GROUP=notification-service

# email: "mailhog" for local dev, "ses" for AWS SES
EMAIL_PROVIDER=mailhog
EMAIL_FROM="Storm <no-reply@storm.local>"

SMTP_HOST=localhost
SMTP_PORT=1025

AWS_REGION=ap-south-1

# Twilio. Leave empty for stub mode (OTPs logged to stdout instead of sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

WEB_APP_ORIGIN=http://localhost:3000

MAX_ATTEMPTS=3
